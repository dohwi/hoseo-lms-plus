{
  "manifest_version": 3,
  "name": "호서 LMS+",
  "version": "1.0",
  "description": "(비공식) 호서대학교 LMS 에서 과제와 온라인 출석을 한눈에 확인해보세요.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://learn.hoseo.ac.kr/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]

}
